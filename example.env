# ──────────────────────────────────────────────────────────────────
# Banking TTS System — Environment Configuration
# ──────────────────────────────────────────────────────────────────

# Application
APP_NAME="Banking TTS System"
APP_VERSION="1.0.0"
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:3000","http://127.0.0.1:8000"]

# Audio
AUDIO_OUTPUT_DIR=static/generated_audio
# Time-to-live for generated audio files in seconds (300 = 5 minutes)
AUDIO_TTL_SECONDS=300

# TTS Defaults
DEFAULT_VOICE_GENDER=female
DEFAULT_SPEECH_RATE=1.0
DEFAULT_PITCH=0
DEFAULT_VOLUME=1.0

# Logging — DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Rate Limiting — max requests per minute per IP
RATE_LIMIT_PER_MINUTE=30
